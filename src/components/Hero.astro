---
---

<section class="hero" id="hero">

  <div class="hero-bg" aria-hidden="true">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="grid"></div>
  </div>

  <div class="hero-inner">

    <div class="hero-meta">
      <span class="meta-tag">
        <span class="meta-dot"></span>
        Serrurier · Paris & IDF
      </span>
      <span class="meta-date" id="hero-date"></span>
    </div>

    <div class="hero-cols">
      <div class="hero-copy">
        <h1 class="hero-h1">
          <span class="h1-line">Bloqué dehors ?</span>
          <span class="h1-line h1-line--big">
            On est là en
            <span class="h1-num">
              <span class="h1-num-inner">30</span>
              <span class="h1-num-unit">min.</span>
            </span>
          </span>
        </h1>

        <p class="hero-sub">
          Serrurier d'urgence <em>à Paris et en Île-de-France</em>,
          disponible 24h/24 et 7j/7. Ouverture de porte sans dégâts,
          prix annoncé avant intervention.
        </p>

        <div class="hero-ctas">
          <a href="tel:+33189706857" class="cta-main">
            <span class="cta-main-ring">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
              </svg>
            </span>
            <span class="cta-main-text">
              <span class="cta-main-small">Appel non surtaxé · 24h/24</span>
              <span class="cta-main-big">01 89 70 68 57</span>
            </span>
            <span class="cta-main-arrow">→</span>
          </a>
          <a href="#services" class="cta-ghost">
            Voir nos services
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="hv-card">
          <div class="hv-img-wrap">
            <img src="/herobg.jpg" alt="Serrurier remplaçant un cylindre de serrure" width="800" height="640" loading="eager" fetchpriority="high" decoding="async"/>
            <div class="hv-overlay"></div>
            <span class="hv-chip hv-chip-top">
              <span class="hv-dot"></span>
              Intervention en cours
            </span>
            <span class="hv-chip hv-chip-bottom">
              <span class="hv-chip-num">30'</span>
              <span class="hv-chip-lbl">Temps moyen<br/>sur place</span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <ul class="hero-proof">
      <li><span class="proof-num">39€</span><span class="proof-lbl">Déplacement</span></li>
      <li><span class="proof-num">30 min</span><span class="proof-lbl">Sur place</span></li>
      <li><span class="proof-num">4.5/5</span><span class="proof-lbl">Google</span></li>
      <li><span class="proof-num">24/7</span><span class="proof-lbl">Disponible</span></li>
    </ul>

  </div>

</section>

<style>
  .hero {
    position: relative;
    background: transparent;
    padding: clamp(2.5rem, 7vw, 6rem) 0 clamp(3rem, 6vw, 5rem);
    overflow: hidden;
    isolation: isolate;
    z-index: 1;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.7;
  }

  .glow-1 {
    top: -20%;
    left: -10%;
    width: 55%;
    height: 55%;
    background: radial-gradient(circle, var(--hero-glow-a) 0%, transparent 65%);
  }

  .glow-2 {
    bottom: -25%;
    right: -15%;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, var(--hero-glow-b) 0%, transparent 65%);
  }

  .grid {
    display: none;
  }

  .hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: clamp(1.5rem, 4vw, 3rem);
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }

  .meta-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .meta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
  }

  .meta-date {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
  }

  .hero-cols {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .hero-h1 {
    font-family: 'Fraunces', serif;
    font-weight: 800;
    color: var(--text);
    line-height: 0.95;
    letter-spacing: -0.035em;
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }

  .h1-line {
    display: block;
    font-size: clamp(2.2rem, 6vw, 4.4rem);
  }

  .h1-line--big {
    font-size: clamp(2.8rem, 8vw, 6rem);
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.2em;
  }

  .h1-num {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    color: var(--accent);
    font-style: italic;
    letter-spacing: -0.055em;
  }

  .h1-num::before {
    content: '';
    position: absolute;
    left: -0.1em;
    right: -0.05em;
    top: 20%;
    bottom: 10%;
    background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
    filter: blur(20px);
    z-index: -1;
  }

  .h1-num-inner { font-size: 1em; }

  .h1-num-unit {
    font-size: 0.4em;
    margin-left: 0.08em;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--accent-2);
    font-style: normal;
    font-family: 'Space Grotesk', sans-serif;
  }

  .hero-sub {
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 520px;
    margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 400;
  }

  .hero-sub em {
    color: var(--text);
    font-style: normal;
    font-weight: 600;
    background: linear-gradient(transparent 65%, var(--accent-glow) 65%);
    padding: 0 2px;
  }

  .hero-ctas {
    display: flex;
    align-items: stretch;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta-main {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    background: var(--accent);
    color: var(--on-accent);
    padding: 0.85rem 1.4rem 0.85rem 1rem;
    border-radius: 14px;
    text-decoration: none;
    box-shadow: 0 14px 40px rgba(255,106,26,0.35),
                0 0 0 1px rgba(255,255,255,0.06) inset;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .cta-main::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, transparent 30%, var(--shimmer) 50%, transparent 70%);
    transform: translateX(-120%);
    transition: transform 0.7s ease;
  }

  .cta-main:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 56px rgba(255,106,26,0.5),
                0 0 0 1px rgba(255,255,255,0.12) inset;
  }

  .cta-main:hover::after { transform: translateX(120%); }

  .cta-main-ring {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(0,0,0,0.14);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--on-accent);
    flex-shrink: 0;
  }

  .cta-main-text {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.1;
  }

  .cta-main-small {
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.75;
    margin-bottom: 3px;
  }

  .cta-main-big {
    font-size: clamp(1.15rem, 2.4vw, 1.35rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    font-family: 'Space Grotesk', sans-serif;
  }

  .cta-main-arrow {
    font-size: 22px;
    font-weight: 300;
    margin-left: 0.2rem;
    transition: transform 0.3s ease;
  }

  .cta-main:hover .cta-main-arrow { transform: translateX(4px); }

  .cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    padding: 0.85rem 1.2rem;
    border: 1px solid var(--line-strong);
    border-radius: 14px;
    background: transparent;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .cta-ghost:hover {
    border-color: var(--text-muted);
    background: var(--bg-3);
  }

  /* Hero visual card */
  .hero-visual {
    position: relative;
  }

  .hv-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: var(--bg-2);
    box-shadow:
      0 40px 80px rgba(0,0,0,0.35),
      0 0 0 1px var(--line);
    transform: rotate(0.8deg);
    transition: transform 0.6s cubic-bezier(.2,.8,.2,1);
  }

  .hv-card:hover {
    transform: rotate(0deg) scale(1.015);
  }

  .hv-img-wrap {
    position: relative;
    aspect-ratio: 5 / 4;
    overflow: hidden;
  }

  .hv-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hv-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(200deg, transparent 30%, rgba(10,10,11,0.55) 100%),
      linear-gradient(20deg, rgba(255,106,26,0.18) 0%, transparent 50%);
    pointer-events: none;
  }

  .hv-chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.20);
    font-family: 'Space Grotesk', sans-serif;
  }

  .hv-chip-top {
    top: 16px;
    left: 16px;
    gap: 0.45rem;
    background: rgba(10,10,11,0.65);
    color: #ffffff;
    padding: 6px 11px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .hv-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 0 rgba(53,208,127,0.6);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  .hv-chip-bottom {
    bottom: 16px;
    left: 16px;
    right: 16px;
    gap: 0.85rem;
    background: rgba(10,10,11,0.75);
    color: #ffffff;
    padding: 0.85rem 1rem;
    border-radius: 16px;
    align-items: center;
  }

  .hv-chip-num {
    font-family: 'Fraunces', serif;
    font-weight: 800;
    font-style: italic;
    font-size: 2.25rem;
    line-height: 0.9;
    color: var(--accent);
    letter-spacing: -0.04em;
  }

  .hv-chip-lbl {
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    line-height: 1.3;
    opacity: 0.92;
  }

  /* Proof row */
  .hero-proof {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--line);
  }

  .hero-proof li {
    padding: 1.25rem 0.25rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    position: relative;
  }

  .hero-proof li + li::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 10%;
    left: 0;
    width: 1px;
    background: var(--line);
  }

  .proof-num {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    font-weight: 800;
    color: var(--text);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .proof-lbl {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 900px) {
    .hero-cols { grid-template-columns: 1fr; gap: 2rem; }
    .hv-card { transform: rotate(0deg); max-width: 560px; margin: 0 auto; }
  }

  @media (max-width: 640px) {
    .hero-inner { padding: 0 1.25rem; }
    .meta-date { font-size: 11px; }
    .meta-tag { font-size: 11px; letter-spacing: 0.1em; }

    .hero-ctas { flex-direction: column; align-items: stretch; }
    .cta-main, .cta-ghost { justify-content: center; width: 100%; }
    .cta-ghost { justify-content: center; }

    .hv-chip-num { font-size: 1.85rem; }
    .hv-chip-lbl { font-size: 10.5px; }
    .hv-chip-bottom { padding: 0.7rem 0.85rem; }

    .hero-proof {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-proof li { padding: 1rem 0 0.75rem; }

    .hero-proof li:nth-child(2)::before,
    .hero-proof li:nth-child(4)::before {
      display: block;
    }

    .hero-proof li:nth-child(3) {
      border-top: 1px solid var(--line);
      padding-top: 1rem;
    }

    .hero-proof li:nth-child(4) {
      border-top: 1px solid var(--line);
      padding-top: 1rem;
    }

    .hero-proof li:nth-child(3)::before { display: none; }
  }
</style>

<script>
  const el = document.getElementById('hero-date');
  if (el) {
    const d = new Date();
    const time = d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    const date = d.toLocaleDateString('fr-FR', { weekday: 'long', day: '2-digit', month: 'long' });
    el.textContent = `${date.toUpperCase()} · ${time}`;
  }
</script>
