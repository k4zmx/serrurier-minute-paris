---
const services = [
  {
    num: "01",
    tag: "Urgence",
    icon: "key",
    title: "Ouverture de porte",
    desc: "Porte claquée, verrouillée, clé perdue ou cassée. On ouvre sans perçage dans 9 cas sur 10.",
    bullets: ["Sans dégâts · sans perçage", "Arrivée en 30 min", "Facture pour l'assurance"],
  },
  {
    num: "02",
    tag: "Sécurité",
    icon: "lock",
    title: "Changement de serrure & cylindre",
    desc: "Serrures multipoints A2P, cylindres haute sécurité, toutes grandes marques installés dans la foulée.",
    bullets: ["Serrures certifiées A2P", "Vachette · Picard · Fichet · Bricard", "Garantie pièces & main-d'œuvre"],
  },
  {
    num: "03",
    tag: "Renforcement",
    icon: "shield",
    title: "Blindage & mise en sécurité",
    desc: "Blindage de porte, bloc-porte blindé, sécurisation complète après effraction. Diagnostic offert.",
    bullets: ["Diagnostic sécurité gratuit", "Blocs-portes blindés A2P", "Intervention après effraction"],
  },
  {
    num: "04",
    tag: "Proximité",
    icon: "pin",
    title: "Artisan local & devis gratuit",
    desc: "Serrurier de proximité à Paris et IDF. Un seul interlocuteur, tarification transparente, devis annoncé avant toute intervention.",
    bullets: ["Artisan local — pas de sous-traitant", "Devis gratuit sur place", "Paiement après intervention"],
  },
];

const icons = {
  key: `<path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>`,
  lock: `<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  pin: `<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/>`,
};
---

<section class="services" id="services" aria-labelledby="services-heading">
  <div class="services-inner">

    <div class="services-head">
      <span class="services-label">
        <span class="sl-mark">§</span>
        Nos interventions
      </span>
      <h2 class="services-h2" id="services-heading">
        De l'ouverture d'urgence<br/>
        à la <em>mise en sécurité</em> complète.
      </h2>
    </div>

    <div class="services-grid">
      {services.map((s, i) => (
        <article class="svc-card" data-idx={i}>
          <button class="svc-head" aria-expanded="false" aria-controls={`svc-body-${i}`} type="button">
            <span class="svc-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon as keyof typeof icons]}></svg>
            </span>
            <span class="svc-meta">
              <span class="svc-tag">{s.tag} · {s.num}</span>
              <span class="svc-title">{s.title}</span>
            </span>
            <span class="svc-chev" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </span>
          </button>
          <div id={`svc-body-${i}`} class="svc-body-wrap" aria-hidden="true">
            <div class="svc-body">
              <p class="svc-desc">{s.desc}</p>
              <ul class="svc-bullets">
                {s.bullets.map((b) => (<li>{b}</li>))}
              </ul>
              <a href="tel:+33189706857" class="svc-cta">
                <span>Appeler maintenant</span>
                <span class="svc-cta-arrow" aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .services {
    background: transparent;
    padding: clamp(3.5rem, 7vw, 6rem) 0;
    border-top: 1px solid var(--line);
    position: relative;
    z-index: 1;
    content-visibility: auto;
    contain-intrinsic-size: 0 900px;
  }

  .services-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .services-head {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .services-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 1.25rem;
    font-family: 'Inter Variable', 'Inter', sans-serif;
  }

  .sl-mark {
    font-family: 'Barlow Condensed', Impact, sans-serif;
    font-weight: 800;
    font-style: italic;
    font-size: 18px;
  }

  .services-h2 {
    font-family: 'Barlow Condensed', Impact, sans-serif;
    font-weight: 800;
    font-size: clamp(1.75rem, 3.4vw, 2.85rem);
    color: var(--text);
    line-height: 1.05;
    letter-spacing: -0.03em;
    max-width: 16ch;
  }

  .services-h2 em {
    font-style: italic;
    color: var(--accent);
  }

  /* Accordion cards */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .svc-card {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 20px;
    overflow: hidden;
    transition: border-color 0.35s ease, transform 0.6s cubic-bezier(.2,.8,.2,1), box-shadow 0.35s ease, opacity 0.6s ease;
    opacity: 0;
    transform: translateY(18px);
    position: relative;
  }

  .svc-card.is-inview {
    opacity: 1;
    transform: translateY(0);
  }

  .svc-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--accent);
    transition: width 0.6s cubic-bezier(.2,.8,.2,1);
    z-index: 1;
  }

  .svc-card.is-open {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--line));
    box-shadow: 0 18px 40px -16px rgba(232,90,18,0.22);
  }

  .svc-card.is-open::after { width: 100%; }

  .svc-head {
    all: unset;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.9rem;
    width: 100%;
    padding: 1.25rem 1.3rem;
    cursor: pointer;
    align-items: center;
  }

  .svc-head:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -4px;
    border-radius: 18px;
  }

  .svc-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--bg-3);
    border: 1px solid var(--line);
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.35s ease, color 0.35s ease, border-color 0.35s ease;
  }

  .svc-card.is-open .svc-icon {
    background: var(--accent);
    color: var(--on-accent);
    border-color: var(--accent);
  }

  .svc-meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-align: left;
    min-width: 0;
  }

  .svc-tag {
    font-family: 'Inter Variable', 'Inter', sans-serif;
    font-size: 10.5px;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .svc-title {
    font-family: 'Barlow Condensed', Impact, sans-serif;
    font-weight: 700;
    font-size: clamp(1.15rem, 1.9vw, 1.45rem);
    color: var(--text);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .svc-chev {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--line-strong);
    color: var(--text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.35s ease, border-color 0.35s ease, color 0.35s ease, transform 0.45s cubic-bezier(.2,.8,.2,1);
  }

  .svc-card.is-open .svc-chev {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--on-accent);
    transform: rotate(180deg);
  }

  .svc-body-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.55s cubic-bezier(.2,.8,.2,1);
  }

  .svc-card.is-open .svc-body-wrap {
    grid-template-rows: 1fr;
  }

  .svc-body {
    overflow: hidden;
  }

  .svc-desc,
  .svc-bullets,
  .svc-cta {
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.4s ease, transform 0.45s cubic-bezier(.2,.8,.2,1);
  }

  .svc-card.is-open .svc-desc { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
  .svc-card.is-open .svc-bullets { opacity: 1; transform: translateY(0); transition-delay: 0.18s; }
  .svc-card.is-open .svc-cta { opacity: 1; transform: translateY(0); transition-delay: 0.26s; }

  .svc-desc {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.6;
    padding: 0 1.3rem 1rem;
  }

  .svc-bullets {
    list-style: none;
    padding: 0 1.3rem 1rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .svc-bullets li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.86rem;
    color: var(--text);
    font-weight: 500;
  }

  .svc-bullets li::before {
    content: '→';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .svc-cta {
    margin: 0 1.3rem 1.3rem;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.85rem 1.1rem;
    border: 1px solid var(--accent);
    border-radius: 10px;
    background: var(--accent);
    color: var(--on-accent);
    text-decoration: none;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: background 0.25s ease, transform 0.2s ease;
  }

  .svc-cta:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
  }

  .svc-cta-arrow {
    transition: transform 0.3s ease;
    font-size: 16px;
    font-weight: 400;
  }

  .svc-cta:hover .svc-cta-arrow { transform: translateX(4px); }

  @media (max-width: 720px) {
    .services-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .services-inner { padding: 0 1.25rem; }
    .svc-head { padding: 1.1rem 1.15rem; gap: 0.75rem; }
    .svc-icon { width: 40px; height: 40px; }
    .svc-desc, .svc-bullets { padding-left: 1.15rem; padding-right: 1.15rem; }
    .svc-cta { margin-left: 1.15rem; margin-right: 1.15rem; }
  }
</style>

<script>
  const section = document.getElementById('services') as HTMLElement | null;
  if (section) {
    const cards = Array.from(section.querySelectorAll<HTMLElement>('.svc-card'));

    cards.forEach((card) => {
      const head = card.querySelector('.svc-head') as HTMLButtonElement | null;
      const body = card.querySelector('.svc-body-wrap') as HTMLElement | null;
      head?.addEventListener('click', () => {
        const open = card.classList.toggle('is-open');
        head.setAttribute('aria-expanded', String(open));
        if (body) body.setAttribute('aria-hidden', String(!open));
      });
    });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const card = e.target as HTMLElement;
        const idx = Number(card.dataset.idx || 0);
        card.classList.add('is-inview');
        const head = card.querySelector('.svc-head') as HTMLButtonElement | null;
        const body = card.querySelector('.svc-body-wrap') as HTMLElement | null;
        window.setTimeout(() => {
          card.classList.add('is-open');
          head?.setAttribute('aria-expanded', 'true');
          body?.setAttribute('aria-hidden', 'false');
        }, 220 + idx * 140);
        io.unobserve(card);
      });
    }, { threshold: 0.2, rootMargin: '0px 0px -8% 0px' });

    cards.forEach((c) => io.observe(c));
  }
</script>
