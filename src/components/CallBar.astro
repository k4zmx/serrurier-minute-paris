---

<div class="callbar">
  <div class="callbar-inner">
    <span class="status">
      <span class="dot"></span>
      <span>En ligne maintenant</span>
    </span>
    <span class="sep">·</span>
    <span class="muted">Serrurier disponible 24h/24 · 7j/7 · Intervention en 30 min</span>
    <span class="sep">·</span>
    <a href="tel:+33189706857" class="phone">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
      </svg>
      01 89 70 68 57
    </a>
  </div>
</div>

<style>
  .callbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #ffffff;
    color: var(--text);
    border-bottom: 1px solid var(--line);
    font-family: 'Space Grotesk', sans-serif;
    isolation: isolate;
  }

  .callbar-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    white-space: nowrap;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 0 rgba(12,157,95,0.5);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(12,157,95,0.45); }
    50% { box-shadow: 0 0 0 6px rgba(12,157,95,0); }
  }

  .sep { color: var(--text-dim); font-size: 12px; }

  .muted {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
  }

  .phone {
    font-size: 12.5px;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.01em;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .phone:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 768px) {
    .callbar { display: none; }
  }
</style>
